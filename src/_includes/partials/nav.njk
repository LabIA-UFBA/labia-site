{% set navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Team', href: '/pages/team/' },
  { label: 'Research', href: '/pages/research/' },
  { label: 'Publications', href: '/pages/publications/' },
  { label: 'Contact', href: '/pages/contact/' }
] %}

<nav class="navbar{% if page.url !== '/' %} scrolled{% endif %}">
  <div class="container">
    <a href="{{ '/' | url }}" class="nav-brand">
      <img src="{{ '/assets/img/logo_white.svg' | url }}" class="nav-brand-logo" alt="LABIA Logo">
      <span class="nav-brand-text">LABIA <span>UFBA</span></span>
    </a>
    <ul class="nav-links">
      {% for link in navLinks %}
        <li><a href="{{ link.href | url }}"{% if page.url === link.href %} class="active"{% endif %}>{{ link.label }}</a></li>
      {% endfor %}
      <li>
        <a href="https://github.com/LabIA-UFBA" class="nav-github" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <img src="{{ '/assets/img/github.svg' | url }}" width="18" height="18" alt="GitHub">
        </a>
      </li>
    </ul>
    <button class="nav-toggle" aria-label="Open menu">☰</button>
  </div>
</nav>

<div class="mobile-menu">
  <button class="mobile-menu-close" aria-label="Close menu">✕</button>
  {% for link in navLinks %}
    <a href="{{ link.href | url }}">{{ link.label }}</a>
  {% endfor %}
</div>
